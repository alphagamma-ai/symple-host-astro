---
interface Props {
  content: any;
}

const { content } = Astro.props;

function renderNode(node: any): string {
  if (!node) return '';

  if (node.type === 'text' || !node.type) {
    let text = node.text || '';
    if (node.format) {
      if (node.format & 1) text = `<strong>${text}</strong>`;
      if (node.format & 2) text = `<em>${text}</em>`;
      if (node.format & 8) text = `<u>${text}</u>`;
      if (node.format & 16) text = `<code>${text}</code>`;
      if (node.format & 4) text = `<s>${text}</s>`;
    }
    return text;
  }

  const children = (node.children || []).map(renderNode).join('');

  switch (node.type) {
    case 'root':
      return children;
    case 'paragraph':
      return `<p>${children}</p>`;
    case 'heading':
      const tag = node.tag || `h${node.version || 2}`;
      return `<${tag}>${children}</${tag}>`;
    case 'list':
      const listTag = node.listType === 'number' ? 'ol' : 'ul';
      return `<${listTag}>${children}</${listTag}>`;
    case 'listitem':
      return `<li>${children}</li>`;
    case 'link':
      const href = node.fields?.url || node.url || '#';
      const target = node.fields?.newTab ? ' target="_blank" rel="noopener"' : '';
      return `<a href="${href}"${target}>${children}</a>`;
    case 'quote':
      return `<blockquote>${children}</blockquote>`;
    case 'code':
      return `<pre><code>${children}</code></pre>`;
    case 'horizontalrule':
      return '<hr />';
    case 'upload':
      const url = node.value?.url || '';
      const alt = node.value?.alt || '';
      return url ? `<img src="${url}" alt="${alt}" />` : '';
    default:
      return children;
  }
}

const html = content?.root ? renderNode(content.root) : '';
---

<div class="prose" set:html={html} />
