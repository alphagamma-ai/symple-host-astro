---
import { render } from 'astro:content';
import Base from '../layouts/Base.astro';
import YouTubeEmbed from './YouTubeEmbed.astro';
import SpeakerCard from './SpeakerCard.astro';
import type { Event } from '../lib/events';
import { EVENT_TYPE_LABEL, isUpcoming, formatEventDate, formatEventTime } from '../lib/events';

interface Props {
  event: Event;
  sectionTitle: string;
  sectionHref: string;
}

const { event, sectionTitle, sectionHref } = Astro.props;
const { Content } = await render(event);
const upcoming = isUpcoming(event);
const typeLabel = EVENT_TYPE_LABEL[event.data.eventType];
const dateLabel = formatEventDate(event.data.eventDate);
const timeLabel = formatEventTime(event.data.eventDate);
const dateTbd = event.data.dateTbd;
const durationLabel = event.data.duration ? `${event.data.duration} minutes` : null;
const timezoneDisplay = event.data.timezoneDisplay;
const scheduleLabel = dateTbd
  ? `Date and time coming soon${durationLabel ? ` · ${durationLabel}` : ''}`
  : timezoneDisplay
    ? `${timezoneDisplay.primary}${durationLabel ? ` · ${durationLabel}` : ''}`
  : `${dateLabel} · ${timeLabel}${durationLabel ? ` · ${durationLabel}` : ''}`;
---

<Base title={event.data.title} description={event.data.description}>
  <nav class="breadcrumb">
    <a href="/">All Topics</a>
    <span class="sep">/</span>
    <a href={sectionHref}>{sectionTitle}</a>
    <span class="sep">/</span>
    <span>{event.data.title}</span>
  </nav>

  <article class="event">
    <section class="event-hero">
      <div class="event-hero-copy">
        <div class="event-meta">
          <span class="event-type">{typeLabel}</span>
          <span class="event-date">{scheduleLabel}</span>
        </div>
        <h1 class="event-title">{event.data.title}</h1>
        {event.data.description && <p class="event-desc">{event.data.description}</p>}
      </div>

      <div class="event-hero-panel">
        {upcoming ? (
          <div class="register-card">
            <h2 class="register-title">Reserve your spot</h2>
            {dateTbd ? (
              <p class="register-meta">Date and time coming soon{durationLabel ? ` · ${durationLabel}` : ''}</p>
            ) : timezoneDisplay ? (
              <div class="register-times" aria-label="Webinar times">
                <p class="register-time-primary">
                  <span>US time</span>
                  {timezoneDisplay.primary}
                </p>
                {timezoneDisplay.secondary.map((time) => (
                  <p class="register-time-secondary">{time}</p>
                ))}
                {durationLabel && <p class="register-duration">{durationLabel}</p>}
              </div>
            ) : (
              <p class="register-meta">{`${dateLabel} at ${timeLabel}`}{durationLabel ? ` · ${durationLabel}` : ''}</p>
            )}
            {event.data.registerUrl ? (
              <a class="register-btn" href={event.data.registerUrl} target="_blank" rel="noopener noreferrer">Register now</a>
            ) : (
              <p class="register-note">Registration opens soon.</p>
            )}
          </div>
        ) : event.data.videoFile ? (
          <video class="local-video" controls preload="metadata">
            <source src={event.data.videoFile} type="video/mp4" />
          </video>
        ) : event.data.youtubeId ? (
          <YouTubeEmbed videoId={event.data.youtubeId} title={event.data.title} />
        ) : (
          <p class="register-note">Recording coming soon.</p>
        )}
      </div>
    </section>

    {event.data.cohosts.length > 0 && (
      <div class="cohosts" aria-label="Co-hosted by">
        <span class="cohosts-label">Co-hosted by</span>
        <div class="cohosts-logos">
          {event.data.cohosts.map((co, idx) => (
            <>
              {idx > 0 && <span class="cohosts-sep" aria-hidden="true">x</span>}
              {co.url ? (
                <a href={co.url} target="_blank" rel="noopener noreferrer" class="cohost" aria-label={co.name}>
                  <img class="cohost-logo" src={co.logo} alt={co.name} />
                  {!co.nameInLogo && <span class="cohost-name">{co.name}</span>}
                </a>
              ) : (
                <span class="cohost">
                  <img class="cohost-logo" src={co.logo} alt={co.name} />
                  {!co.nameInLogo && <span class="cohost-name">{co.name}</span>}
                </span>
              )}
            </>
          ))}
        </div>
      </div>
    )}

    {event.data.speakers.length > 0 && (
      <section class="speakers">
        <div class="section-head">
          <h2 class="section-heading">{event.data.speakers.length === 1 ? 'Speaker' : 'Speakers'}</h2>
          <p class="section-intro">Three practical perspectives on the path from first listings to repeatable operations and growth.</p>
        </div>
        <div class="speaker-grid">
          {event.data.speakers.map((s) => (
            <SpeakerCard name={s.name} role={s.role} avatar={s.avatar} topic={s.topic} bio={s.bio} />
          ))}
        </div>
      </section>
    )}

    <div class="event-content-shell">
      <div class="event-content">
        <Content />
      </div>
    </div>
  </article>

  <style>
    .breadcrumb {
      font-size: 0.85rem;
      color: var(--muted-foreground);
      margin-bottom: 1.5rem;
    }
    .breadcrumb a { color: var(--muted-foreground); }
    .breadcrumb a:hover { color: var(--primary); }
    .sep { margin: 0 0.4rem; }

    .event {
      --hero-ink: #2d174f;
      --hero-accent: #f59e0b;
      --hero-accent-dark: #b45309;
    }
    .event-hero {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.72fr);
      gap: 2rem;
      align-items: stretch;
      overflow: hidden;
      padding: 2.5rem;
      margin-bottom: 1.25rem;
      border: 1px solid rgba(127, 86, 217, 0.22);
      border-radius: 18px;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(250, 245, 255, 0.82)),
        radial-gradient(circle at 15% 18%, rgba(245, 158, 11, 0.16), transparent 28rem),
        linear-gradient(145deg, #fffaf0 0%, #f5f3ff 58%, #ffffff 100%);
      box-shadow: 0 24px 70px rgba(88, 28, 135, 0.13);
    }
    .event-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(88, 28, 135, 0.055) 1px, transparent 1px),
        linear-gradient(90deg, rgba(88, 28, 135, 0.055) 1px, transparent 1px);
      background-size: 34px 34px;
      mask-image: linear-gradient(135deg, #000 0%, transparent 70%);
    }
    .event-hero-copy,
    .event-hero-panel {
      position: relative;
      z-index: 1;
    }
    .event-hero-copy {
      align-self: center;
      max-width: 48rem;
    }
    .event-hero-panel {
      display: flex;
      align-items: center;
    }
    .event-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }
    .event-type {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #ffffff;
      background: var(--hero-ink);
      padding: 0.32rem 0.7rem;
      border-radius: 999px;
    }
    .event-date {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--hero-ink);
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(127, 86, 217, 0.16);
      border-radius: 999px;
      padding: 0.28rem 0.72rem;
    }
    .event-title {
      font-size: clamp(2.4rem, 5vw, 4.75rem);
      font-weight: 900;
      color: var(--hero-ink);
      letter-spacing: 0;
      line-height: 1.02;
      max-width: 12ch;
      margin-bottom: 1.1rem;
    }
    .event-desc {
      color: #4b3a5f;
      font-size: 1.12rem;
      line-height: 1.65;
      max-width: 43rem;
    }
    .local-video {
      width: 100%;
      aspect-ratio: 16 / 9;
      background: #000000;
      border-radius: 14px;
      display: block;
      box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
    }
    .cohosts {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
      padding: 0.95rem 1.1rem;
      margin-bottom: 2.25rem;
      background: #ffffff;
      border: 1px solid rgba(127, 86, 217, 0.16);
      border-radius: 14px;
      box-shadow: 0 12px 34px rgba(88, 28, 135, 0.07);
    }
    .cohosts-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6b5a7a;
    }
    .cohosts-logos {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .cohost {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--foreground);
      text-decoration: none;
      transition: opacity 0.15s;
    }
    a.cohost:hover { opacity: 0.75; }
    .cohost-logo {
      height: 34px;
      width: auto;
      max-width: 128px;
      object-fit: contain;
      display: block;
      padding: 3px 4px;
      box-sizing: content-box;
      background: #fff;
      border: 1px solid var(--border-light);
      border-radius: 6px;
    }
    .cohost-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--hero-ink);
      letter-spacing: 0;
    }
    .cohosts-sep {
      color: var(--muted-light);
      font-size: 0.9rem;
      font-weight: 300;
    }
    .register-card {
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 300px;
      background: #ffffff;
      border: 1px solid rgba(88, 28, 135, 0.18);
      border-radius: 16px;
      padding: 2rem;
      text-align: left;
      box-shadow: 0 18px 48px rgba(88, 28, 135, 0.16);
    }
    .register-title {
      font-size: 1.55rem;
      font-weight: 900;
      color: var(--hero-ink);
      margin: 0 0 0.4rem;
    }
    .register-meta {
      color: #5d506b;
      font-size: 0.95rem;
      line-height: 1.55;
      margin: 0 0 1.4rem;
    }
    .register-times {
      display: grid;
      gap: 0.55rem;
      margin-bottom: 1.45rem;
    }
    .register-time-primary,
    .register-time-secondary,
    .register-duration {
      margin: 0;
      line-height: 1.4;
    }
    .register-time-primary {
      color: var(--hero-ink);
      font-size: 1.04rem;
      font-weight: 850;
    }
    .register-time-primary span {
      display: block;
      margin-bottom: 0.22rem;
      color: #9a3412;
      font-size: 0.68rem;
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .register-time-secondary {
      color: #5d506b;
      font-size: 0.92rem;
      font-weight: 650;
    }
    .register-duration {
      width: fit-content;
      margin-top: 0.25rem;
      padding: 0.24rem 0.58rem;
      border-radius: 999px;
      background: #f5f3ff;
      color: #4b3a5f;
      font-size: 0.78rem;
      font-weight: 800;
    }
    .register-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--hero-accent), #f97316);
      color: #ffffff;
      font-weight: 900;
      font-size: 1rem;
      min-height: 52px;
      padding: 0.9rem 1.35rem;
      border-radius: 10px;
      text-decoration: none;
      box-shadow: 0 14px 30px rgba(249, 115, 22, 0.28);
      transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
    }
    .register-btn:hover {
      color: #ffffff;
      transform: translateY(-1px);
      filter: saturate(1.08);
      box-shadow: 0 18px 38px rgba(249, 115, 22, 0.34);
    }
    .register-note {
      color: var(--muted-foreground);
      font-size: 0.95rem;
      margin: 0;
    }
    .speakers {
      margin: 2.75rem 0;
    }
    .section-head {
      max-width: 42rem;
      margin-bottom: 1.2rem;
    }
    .section-heading {
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #6b5a7a;
      margin-bottom: 0.35rem;
    }
    .section-intro {
      margin: 0;
      color: #4b3a5f;
      font-size: 1rem;
      line-height: 1.6;
    }
    .speaker-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.15rem;
    }
    .speaker-grid :global(.speaker) {
      flex-direction: column;
      min-height: 100%;
      gap: 1.1rem;
      padding: 1.35rem;
      background: #ffffff;
      border: 1px solid rgba(127, 86, 217, 0.16);
      border-radius: 16px;
      box-shadow: 0 14px 34px rgba(88, 28, 135, 0.08);
    }
    .speaker-grid :global(.speaker-avatar) {
      width: 132px;
      height: 132px;
      border: 3px solid #ffffff;
      box-shadow: 0 0 0 1px rgba(127, 86, 217, 0.2), 0 10px 22px rgba(88, 28, 135, 0.14);
    }
    .speaker-grid :global(.speaker-text) {
      width: 100%;
    }
    .speaker-grid :global(.speaker-name) {
      color: var(--hero-ink);
      font-size: 1rem;
      font-weight: 800;
      margin-top: 0.2rem;
    }
    .event-content-shell {
      padding: 0.5rem 0 0;
    }
    .event-content {
      font-size: 0.95rem;
      line-height: 1.75;
      color: var(--muted-foreground);
      max-width: 60rem;
      margin: 0 auto;
    }
    .event-content :global(h2) {
      font-size: 1.55rem;
      font-weight: 900;
      color: var(--hero-ink);
      margin: 2.35rem 0 0.75rem;
    }
    .event-content :global(h3) {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--hero-ink);
      margin: 1.5rem 0 0.5rem;
    }
    .event-content :global(p) { margin-bottom: 1rem; }
    .event-content :global(ul),
    .event-content :global(ol) { margin: 0.5rem 0 1rem 1.5rem; }
    .event-content :global(li) { margin-bottom: 0.35rem; }
    .event-content :global(strong) {
      color: var(--foreground);
      font-weight: 700;
    }
    .event-content :global(.learn-grid) {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin: 1.1rem 0 2rem;
    }
    .event-content :global(.learn-card) {
      position: relative;
      overflow: hidden;
      min-height: 210px;
      padding: 1.15rem;
      border: 1px solid rgba(127, 86, 217, 0.16);
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 235, 0.72)),
        radial-gradient(circle at 100% 0%, rgba(245, 158, 11, 0.18), transparent 8rem);
      box-shadow: 0 14px 34px rgba(88, 28, 135, 0.07);
    }
    .event-content :global(.learn-card::before) {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(88, 28, 135, 0.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(88, 28, 135, 0.045) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: linear-gradient(145deg, #000 0%, transparent 72%);
    }
    .event-content :global(.learn-card span),
    .event-content :global(.learn-card strong),
    .event-content :global(.learn-card p) {
      position: relative;
      z-index: 1;
    }
    .event-content :global(.learn-card span) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.2rem;
      height: 2.2rem;
      margin-bottom: 0.9rem;
      border-radius: 999px;
      background: var(--hero-ink);
      color: #ffffff;
      font-size: 0.72rem;
      font-weight: 850;
      letter-spacing: 0.05em;
    }
    .event-content :global(.learn-card strong) {
      display: block;
      color: var(--hero-ink);
      font-size: 1.03rem;
      font-weight: 850;
      line-height: 1.25;
      margin-bottom: 0.55rem;
    }
    .event-content :global(.learn-card p) {
      color: #5d506b;
      font-size: 0.9rem;
      line-height: 1.6;
      margin: 0;
    }
    .event-content :global(.audience-grid) {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
      margin: 1rem 0 2rem;
      padding: 1.15rem;
      border: 1px solid rgba(127, 86, 217, 0.14);
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 14px 34px rgba(88, 28, 135, 0.06);
    }
    .event-content :global(.audience-grid div) {
      position: relative;
      min-height: 70px;
      padding: 0.8rem 0.9rem 0.8rem 2.45rem;
      border-radius: 12px;
      background: #faf7ff;
      color: #3f3150;
      font-size: 0.91rem;
      font-weight: 650;
      line-height: 1.48;
    }
    .event-content :global(.audience-grid div::before) {
      content: "";
      position: absolute;
      left: 0.95rem;
      top: 1rem;
      width: 0.68rem;
      height: 0.68rem;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--hero-accent), #f97316);
      box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.16);
    }
    .event-content :global(a) {
      color: var(--primary);
      text-decoration: underline;
    }
    .event-content :global(blockquote) {
      border-left: 3px solid var(--primary-300);
      padding-left: 1rem;
      margin: 1rem 0;
      color: var(--muted-foreground);
      font-style: italic;
    }
    .event-content :global(code) {
      background: var(--primary-50);
      padding: 0.15rem 0.35rem;
      border-radius: 3px;
      font-size: 0.875em;
    }
    .event-content :global(pre) {
      background: #1e1e2e;
      color: #cdd6f4;
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1rem 0;
    }
    .event-content :global(pre code) {
      background: none;
      padding: 0;
    }
    .event-content :global(img) {
      display: block;
      max-width: 100%;
      max-height: 480px;
      width: auto;
      height: auto;
      margin: 1.25rem auto;
      border: 1px solid var(--border);
      border-radius: 6px;
      object-fit: contain;
    }
    .event-content :global(hr) {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2rem 0;
    }
    .event-content :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0;
      font-size: 0.9rem;
      display: block;
      overflow-x: auto;
    }
    .event-content :global(thead) {
      background: #fff7ed;
    }
    .event-content :global(th) {
      text-align: left;
      font-weight: 700;
      color: var(--hero-ink);
      padding: 0.7rem 0.9rem;
      border-bottom: 2px solid rgba(245, 158, 11, 0.28);
      white-space: nowrap;
    }
    .event-content :global(td) {
      padding: 0.7rem 0.9rem;
      border-bottom: 1px solid #eee7f5;
      vertical-align: top;
      color: var(--foreground);
    }
    .event-content :global(tbody tr:last-child td) {
      border-bottom: none;
    }
    .event-content :global(tbody tr:hover) {
      background: #fffbeb;
    }
    @media (max-width: 860px) {
      .event-hero {
        grid-template-columns: 1fr;
        padding: 1.4rem;
        border-radius: 14px;
      }
      .event-title {
        font-size: 2.35rem;
        max-width: 14ch;
      }
      .event-desc {
        font-size: 1rem;
      }
      .register-card {
        padding: 1.35rem;
      }
      .cohosts {
        align-items: flex-start;
      }
      .speaker-grid {
        grid-template-columns: 1fr;
      }
      .speaker-grid :global(.speaker-avatar) {
        width: 96px;
        height: 96px;
      }
      .event-content :global(.learn-grid),
      .event-content :global(.audience-grid) {
        grid-template-columns: 1fr;
      }
      .event-content :global(.learn-card) {
        min-height: auto;
      }
      .event-content :global(.audience-grid) {
        padding: 0.9rem;
      }
    }
  </style>
</Base>
