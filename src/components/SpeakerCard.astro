---
interface Props {
  name: string;
  role?: string;
  avatar?: string;
  topic?: string;
  bio?: string;
  url?: string;
}

const { name, role, avatar, topic, bio, url } = Astro.props;
const initials = name
  .split(' ')
  .map((part) => part[0]?.toUpperCase() ?? '')
  .slice(0, 2)
  .join('');
---

<div class="speaker">
  {avatar ? (
    <img class="speaker-avatar" src={avatar} alt={name} loading="lazy" width="132" height="132" />
  ) : (
    <div class="speaker-avatar speaker-avatar-fallback" aria-hidden="true">{initials}</div>
  )}
  <div class="speaker-text">
    {topic && <div class="speaker-topic">{topic}</div>}
    {url ? (
      <a class="speaker-name speaker-link" href={url} target="_blank" rel="noopener noreferrer">{name}</a>
    ) : (
      <div class="speaker-name">{name}</div>
    )}
    {role && <div class="speaker-role">{role}</div>}
    {bio && <p class="speaker-bio">{bio}</p>}
  </div>
</div>

<style>
  .speaker {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.05rem;
  }
  .speaker-avatar {
    width: 132px;
    height: 132px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--primary-50);
    border: 1px solid var(--border);
    flex-shrink: 0;
  }
  .speaker-avatar-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
    letter-spacing: 0.02em;
  }
  .speaker-text {
    min-width: 0;
  }
  .speaker-topic {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    margin-bottom: 0.55rem;
    padding: 0.24rem 0.55rem;
    border-radius: 999px;
    background: #fff7ed;
    color: #9a3412;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.25;
    text-transform: uppercase;
  }
  .speaker-name {
    display: inline-flex;
    font-size: 1.2rem;
    font-weight: 850;
    color: var(--foreground);
    line-height: 1.18;
  }
  .speaker-link {
    text-decoration: none;
  }
  .speaker-link:hover {
    color: var(--primary);
  }
  .speaker-role {
    margin-top: 0.22rem;
    font-size: 0.88rem;
    font-weight: 650;
    color: var(--muted-foreground);
    line-height: 1.35;
  }
  .speaker-bio {
    margin: 0.8rem 0 0;
    font-size: 0.9rem;
    color: #5d506b;
    line-height: 1.6;
  }

  @media (max-width: 560px) {
    .speaker-avatar {
      width: 96px;
      height: 96px;
    }
  }
</style>
