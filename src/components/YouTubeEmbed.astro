---
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props;

if (!/^[a-zA-Z0-9_-]{11}$/.test(videoId)) {
  throw new Error(
    `YouTubeEmbed: invalid videoId "${videoId}". Expected the 11-character ID from a YouTube URL (e.g. "dQw4w9WgXcQ"), not the full URL.`
  );
}

const src = `https://www.youtube-nocookie.com/embed/${videoId}`;
---

<div class="yt-embed">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
  ></iframe>
</div>

<style>
  .yt-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
  }
  .yt-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
