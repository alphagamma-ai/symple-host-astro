---
import {
  DEFAULT_LOCALE,
  LOCALE_LABELS,
  LOCALE_LANG,
  LOCALES,
  localizePath,
  type Locale,
  uiCopy,
} from '../lib/locales';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, locale = DEFAULT_LOCALE } = Astro.props;
const copy = uiCopy[locale];
const description = Astro.props.description ?? copy.defaultDescription;
const currentPath = Astro.url.pathname;
---

<html lang={LOCALE_LANG[locale]}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Merriweather:wght@400;700;900&family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | {copy.titleSuffix}</title>
    <style is:global>
      :root {
        --primary-50: #faf5ff;
        --primary-100: #f3e8ff;
        --primary-200: #e9d5ff;
        --primary-300: #d8b4fe;
        --primary-400: #c084fc;
        --primary-500: #7F56D9;
        --primary-600: #7F56D9;
        --primary-700: #6941C6;
        --primary-800: #6b21a8;
        --primary-900: #581c87;

        --background: #fafafa;
        --foreground: #18181b;
        --heading-color: #581c87;
        --muted-foreground: #71717a;
        --muted-light: #a1a1aa;
        --border: #e4e4e7;
        --border-light: #f2f4f7;
        --primary: #7F56D9;

      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Merriweather', Georgia, 'Times New Roman', serif;
      }

      html:lang(ja) h1,
      html:lang(ja) h2,
      html:lang(ja) h3,
      html:lang(ja) h4,
      html:lang(ja) h5,
      html:lang(ja) h6 {
        font-family: 'Noto Sans JP', 'Inter', ui-sans-serif, system-ui, sans-serif;
        font-weight: 700;
      }

      body {
        font-family: 'Inter', 'Noto Sans JP', ui-sans-serif, system-ui, -apple-system, sans-serif;
        background: var(--background);
        color: var(--foreground);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--primary);
        text-decoration: none;
        transition: color 0.15s;
      }
      a:hover { color: var(--primary-700); }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href={localizePath('/', locale)} class="logo">
          <img src="/SH_Logo.svg" alt="SympleHost" class="logo-img" />
          <span>SYMPLE HOST</span>
        </a>

        <nav class="nav">
          <a href={localizePath('/', locale)} class="nav-link">{copy.knowledgeBase}</a>
      <!--  <a href="https://www.symplehost.ai/signal" class="nav-link">Signal</a> -->
          <a href="https://www.symplehost.ai/pricing" class="nav-link">{copy.pricing}</a>
          <a href="https://www.symplehost.ai/blog" class="nav-link">{copy.blog}</a>
          <a href="https://www.symplehost.ai/contact-us" class="nav-link">{copy.contact}</a>
        </nav>

        <nav class="locale-switcher" aria-label={copy.language}>
          {LOCALES.map((item) => (
            <a
              href={localizePath(currentPath, item)}
              class:list={['locale-link', { active: item === locale }]}
              aria-current={item === locale ? 'page' : undefined}
            >
              {LOCALE_LABELS[item]}
            </a>
          ))}
        </nav>
      </div>
      <div class="header-gradient"></div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="footer">
      <p>&copy; {new Date().getFullYear()} <a href="https://www.symplehost.ai">SympleHost</a>. {copy.copyright}</p>
    </footer>

    <style>
      .header {
        background: #ffffff;
        border-bottom: 1px solid var(--border-light);
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .header-inner {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0 2rem;
        height: 64px;
        display: flex;
        align-items: center;
        gap: 2rem;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: #2E2E2E;
        font-family: 'Merriweather', Georgia, 'Times New Roman', serif;
        font-weight: 700;
        font-size: 1.25rem;
        white-space: nowrap;
      }
      .logo:hover { color: #2E2E2E; }
      .logo-img {
        width: 32px;
        height: 32px;
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 1.75rem;
        flex: 1;
      }
      .nav-link {
        color: #2E2E2E;
        font-size: 1.2rem;
        font-weight: 400;
        transition: color 0.15s;
      }
      .nav-link:hover { color: var(--primary); }
      .header-gradient {
        height: 3px;
        background: linear-gradient(90deg, var(--primary-400), var(--primary), var(--primary-400));
      }
      .locale-switcher {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        margin-left: auto;
        padding: 0.2rem;
        border: 1px solid var(--border-light);
        border-radius: 999px;
        background: #ffffff;
      }
      .locale-link {
        color: #2E2E2E;
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1;
        padding: 0.42rem 0.55rem;
        border-radius: 999px;
      }
      .locale-link:hover {
        color: var(--primary);
      }
      .locale-link.active {
        color: #ffffff;
        background: var(--primary);
      }

      .main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2rem 2rem 4rem;
        width: 100%;
        flex: 1;
      }

      .footer {
        border-top: 1px solid var(--border);
        padding: 2rem;
        text-align: center;
        color: var(--muted-foreground);
        font-size: 0.85rem;
      }
      .footer a {
        color: var(--primary);
      }

      @media (max-width: 768px) {
        .header-inner { padding: 0 1rem; gap: 1rem; }
        .nav { display: none; }
        .locale-switcher { margin-left: auto; }
        .main { padding: 1.5rem 1rem 3rem; }
      }
    </style>
  </body>
</html>
