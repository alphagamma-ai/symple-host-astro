---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { partitionEvents, isUpcoming } from '../../lib/events';

const events = await getCollection('events', ({ data }) => !data.draft);
const walkthroughs = await getCollection('walkthroughs', ({ data }) => !data.draft);
const webinarEvents = events.filter((event) => event.data.eventType !== 'tutorial');
const videoEvents = events.filter((event) => event.data.eventType === 'tutorial');
const { past: pastWebinars } = partitionEvents(webinarEvents);
const upcomingWebinarsCount = webinarEvents.filter((event) => isUpcoming(event)).length;
---

<Base title="Webinars & Videos" description="Choose webinars for live sessions and recordings, or videos for product tutorials and walkthroughs.">
  <nav class="breadcrumb">
    <a href="/">All Topics</a>
    <span class="sep">/</span>
    <span>Webinars &amp; Videos</span>
  </nav>

  <header class="page-header">
    <h1 class="page-title">Webinars &amp; Videos</h1>
    <p class="page-desc">These now live in separate spaces so you can find live sessions or product videos without the mixed layout.</p>
  </header>

  <section class="split-grid" aria-label="Choose a section">
    <a href="/webinars/" class="split-card">
      <span class="split-kicker">Live sessions</span>
      <h2 class="split-title">Webinars</h2>
      <p class="split-desc">Upcoming sessions, customer success hours, and webinar recordings.</p>
      <span class="split-count">
        {upcomingWebinarsCount > 0
          ? `${upcomingWebinarsCount} upcoming · ${pastWebinars.length} ${pastWebinars.length === 1 ? 'recording' : 'recordings'}`
          : `${pastWebinars.length} ${pastWebinars.length === 1 ? 'recording' : 'recordings'}`}
      </span>
      <span class="split-cta">View webinars -></span>
    </a>

    <a href="/videos/" class="split-card">
      <span class="split-kicker">Watch and learn</span>
      <h2 class="split-title">Videos</h2>
      <p class="split-desc">Welcome videos, tutorials, and focused product walkthroughs.</p>
      <span class="split-count">
        {videoEvents.length} {videoEvents.length === 1 ? 'video' : 'videos'} · {walkthroughs.length} {walkthroughs.length === 1 ? 'walkthrough' : 'walkthroughs'}
      </span>
      <span class="split-cta">View videos -></span>
    </a>
  </section>

  <style>
    .breadcrumb {
      font-size: 0.85rem;
      color: var(--muted-foreground);
      margin-bottom: 1rem;
    }
    .breadcrumb a { color: var(--muted-foreground); }
    .breadcrumb a:hover { color: var(--heading-color); }
    .sep { margin: 0 0.4rem; }

    .page-header {
      margin-bottom: 2rem;
      max-width: 48rem;
    }
    .page-title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--heading-color);
      letter-spacing: -0.01em;
      margin-bottom: 0.5rem;
    }
    .page-desc {
      color: var(--muted-foreground);
      font-size: 1rem;
    }
    .split-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
    }
    .split-card {
      display: flex;
      flex-direction: column;
      min-height: 220px;
      padding: 1.5rem;
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--foreground);
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .split-card:hover {
      border-color: var(--primary-300);
      box-shadow: 0 2px 8px rgba(127, 86, 217, 0.1);
    }
    .split-kicker {
      color: var(--primary);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .split-title {
      color: var(--heading-color);
      font-size: 1.35rem;
      line-height: 1.3;
      margin-bottom: 0.45rem;
    }
    .split-desc {
      color: var(--muted-foreground);
      font-size: 0.92rem;
      line-height: 1.55;
      flex: 1;
    }
    .split-count {
      color: var(--muted-light);
      font-size: 0.82rem;
      margin-top: 1rem;
    }
    .split-cta {
      color: var(--primary);
      font-size: 0.9rem;
      font-weight: 600;
      margin-top: 0.75rem;
    }
  </style>
</Base>
