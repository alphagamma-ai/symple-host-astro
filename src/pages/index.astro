---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { partitionEvents, isUpcoming } from '../lib/events';

const categories = await getCollection('categories');
const articles = await getCollection('articles', ({ data }) => !data.draft);
const events = await getCollection('events', ({ data }) => !data.draft);
const walkthroughs = await getCollection('walkthroughs', ({ data }) => !data.draft);

const articleCounts = new Map<string, number>();
for (const article of articles) {
  const cat = article.data.category;
  articleCounts.set(cat, (articleCounts.get(cat) || 0) + 1);
}

const categoryById = new Map(categories.map((c) => [c.id, c]));
const gettingStarted = categoryById.get('getting-started');
const platformGuides = categoryById.get('platform-guides');
const aiAndApi = categoryById.get('ai-and-api');
const faqs = categoryById.get('faqs');
const integrations = categoryById.get('integrations');

const articlesHubCount =
  (articleCounts.get('str-market-trends') || 0) +
  (articleCounts.get('marketing-for-hosts') || 0);

const webinarEvents = events.filter((e) => e.data.eventType !== 'tutorial');
const videoEvents = events.filter((e) => e.data.eventType === 'tutorial');
const { past: pastWebinars } = partitionEvents(webinarEvents);
const upcomingWebinarsCount = webinarEvents.filter((e) => isUpcoming(e)).length;
const videoCount = videoEvents.length;
const walkthroughCount = walkthroughs.length;
---

<Base title="How can we help?">
  <section class="hero">
    <h1>How can we help?</h1>
    <p>Browse our guides and tutorials to get the most out of SympleHost.</p>
  </section>

  <section class="categories">
    {gettingStarted && (
      <a href={`/${gettingStarted.id}`} class="category-card">
        {gettingStarted.data.emoji && <span class="category-emoji">{gettingStarted.data.emoji}</span>}
        <h2 class="category-title">{gettingStarted.data.title}</h2>
        {gettingStarted.data.description && <p class="category-desc">{gettingStarted.data.description}</p>}
        {(() => {
          const count = articleCounts.get(gettingStarted.id) || 0;
          return <span class="category-count">{count} {count === 1 ? 'article' : 'articles'}</span>;
        })()}
      </a>
    )}
    {platformGuides && (
      <a href={`/${platformGuides.id}`} class="category-card">
        {platformGuides.data.emoji && <span class="category-emoji">{platformGuides.data.emoji}</span>}
        <h2 class="category-title">{platformGuides.data.title}</h2>
        {platformGuides.data.description && <p class="category-desc">{platformGuides.data.description}</p>}
        {(() => {
          const count = articleCounts.get(platformGuides.id) || 0;
          return <span class="category-count">{count} {count === 1 ? 'article' : 'articles'}</span>;
        })()}
      </a>
    )}
    {aiAndApi && (
      <a href={`/${aiAndApi.id}`} class="category-card">
        {aiAndApi.data.emoji && <span class="category-emoji">{aiAndApi.data.emoji}</span>}
        <h2 class="category-title">{aiAndApi.data.title}</h2>
        {aiAndApi.data.description && <p class="category-desc">{aiAndApi.data.description}</p>}
        {(() => {
          const count = articleCounts.get(aiAndApi.id) || 0;
          return <span class="category-count">{count} {count === 1 ? 'article' : 'articles'}</span>;
        })()}
      </a>
    )}
    <a href="/webinars/" class="category-card">
      <span class="category-emoji">🎙️</span>
      <h2 class="category-title">Webinars</h2>
      <p class="category-desc">Live sessions, customer success hours, and webinar recordings.</p>
      <span class="category-count">
        {upcomingWebinarsCount > 0
          ? `${upcomingWebinarsCount} upcoming · ${pastWebinars.length} ${pastWebinars.length === 1 ? 'recording' : 'recordings'}`
          : `${pastWebinars.length} ${pastWebinars.length === 1 ? 'recording' : 'recordings'}`}
      </span>
    </a>
    <a href="/videos/" class="category-card">
      <span class="category-emoji">🎥</span>
      <h2 class="category-title">Videos</h2>
      <p class="category-desc">Welcome videos, product tutorials, and focused walkthroughs.</p>
      <span class="category-count">
        {videoCount} {videoCount === 1 ? 'video' : 'videos'} · {walkthroughCount} {walkthroughCount === 1 ? 'walkthrough' : 'walkthroughs'}
      </span>
    </a>
    <a href="/articles/" class="category-card">
      <span class="category-emoji">💡</span>
      <h2 class="category-title">Articles</h2>
      <p class="category-desc">STR market trends and marketing playbooks for short-term rental hosts.</p>
      <span class="category-count">{articlesHubCount} {articlesHubCount === 1 ? 'article' : 'articles'}</span>
    </a>
    {integrations && (
      <a href={`/${integrations.id}`} class="category-card">
        {integrations.data.emoji && <span class="category-emoji">{integrations.data.emoji}</span>}
        <h2 class="category-title">{integrations.data.title}</h2>
        {integrations.data.description && <p class="category-desc">{integrations.data.description}</p>}
        {(() => {
          const count = articleCounts.get(integrations.id) || 0;
          return <span class="category-count">{count} {count === 1 ? 'integration' : 'integrations'}</span>;
        })()}
      </a>
    )}
    {faqs && (
      <a href={`/${faqs.id}`} class="category-card">
        {faqs.data.emoji && <span class="category-emoji">{faqs.data.emoji}</span>}
        <h2 class="category-title">{faqs.data.title}</h2>
        {faqs.data.description && <p class="category-desc">{faqs.data.description}</p>}
        {(() => {
          const count = articleCounts.get(faqs.id) || 0;
          return <span class="category-count">{count} {count === 1 ? 'article' : 'articles'}</span>;
        })()}
      </a>
    )}
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 3rem 0 2.5rem;
    }
    .hero h1 {
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--heading-color);
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }
    .hero p {
      color: var(--muted-foreground);
      font-size: 1.05rem;
    }

    .categories {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
      max-width: 56rem;
      margin: 0 auto;
    }

    .category-card {
      display: flex;
      flex-direction: column;
      padding: 1.5rem;
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--foreground);
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
      transition: border-color 0.15s, box-shadow 0.15s;
      min-height: 140px;
    }
    .category-card:hover {
      border-color: var(--primary-300);
      box-shadow: 0 2px 8px rgba(127, 86, 217, 0.1);
    }

    .category-emoji {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }
    .category-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--heading-color);
      margin-bottom: 0.35rem;
    }
    .category-desc {
      color: var(--muted-foreground);
      font-size: 0.875rem;
      line-height: 1.5;
      flex: 1;
    }
    .category-count {
      color: var(--muted-light);
      font-size: 0.8125rem;
      margin-top: 0.75rem;
    }
  </style>
</Base>
