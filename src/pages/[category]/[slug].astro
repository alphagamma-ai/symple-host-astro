---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const categories = await getCollection('categories');
  const catMap = new Map(categories.map((c) => [c.id, c]));

  return articles.map((article) => ({
    params: { category: article.data.category, slug: article.id },
    props: { article, category: catMap.get(article.data.category) },
  }));
}

const { article, category } = Astro.props;
const { Content } = await render(article);

const formattedDate = article.data.date
  ? new Date(article.data.date).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<Base title={article.data.title} description={article.data.description}>
  <nav class="breadcrumb">
    <a href="/">All Topics</a>
    <span class="sep">/</span>
    {category && <><a href={`/${category.id}`}>{category.data.title}</a><span class="sep">/</span></>}
    <span>{article.data.title}</span>
  </nav>

  <article class="article">
    <header class="article-header">
      <h1 class="article-title">{article.data.title}</h1>
      <div class="article-meta">
        {formattedDate && <span class="article-date">Updated {formattedDate}</span>}
        {article.data.tags && article.data.tags.length > 0 && (
          <div class="article-tags">
            {article.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="article-content">
      <Content />
    </div>
  </article>

  <style>
    .breadcrumb {
      font-size: 0.85rem;
      color: var(--muted-foreground);
      margin-bottom: 1.5rem;
    }
    .breadcrumb a { color: var(--muted-foreground); }
    .breadcrumb a:hover { color: var(--primary); }
    .sep { margin: 0 0.4rem; }

    .article-header {
      margin-bottom: 2rem;
    }
    .article-title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--heading-color);
      letter-spacing: -0.01em;
      margin-bottom: 0.75rem;
    }
    .article-meta {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .article-date {
      color: var(--muted-foreground);
      font-size: 0.85rem;
    }
    .article-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .tag {
      color: var(--primary);
      font-size: 0.8rem;
      font-weight: 500;
      padding: 0.15rem 0.5rem;
      background: var(--primary-50);
      border-radius: 4px;
    }

    .article-content {
      font-size: 0.95rem;
      line-height: 1.75;
      color: var(--muted-foreground);
    }
    .article-content :global(h2) {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--heading-color);
      margin: 2rem 0 0.75rem;
    }
    .article-content :global(h3) {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--heading-color);
      margin: 1.5rem 0 0.5rem;
    }
    .article-content :global(p) {
      margin-bottom: 1rem;
    }
    .article-content :global(ul),
    .article-content :global(ol) {
      margin: 0.5rem 0 1rem 1.5rem;
    }
    .article-content :global(li) {
      margin-bottom: 0.35rem;
    }
    .article-content :global(strong) {
      color: var(--foreground);
      font-weight: 600;
    }
    .article-content :global(a) {
      color: var(--primary);
      text-decoration: underline;
    }
    .article-content :global(blockquote) {
      border-left: 3px solid var(--primary-300);
      padding-left: 1rem;
      margin: 1rem 0;
      color: var(--muted-foreground);
      font-style: italic;
    }
    .article-content :global(code) {
      background: var(--primary-50);
      padding: 0.15rem 0.35rem;
      border-radius: 3px;
      font-size: 0.875em;
    }
    .article-content :global(pre) {
      background: #1e1e2e;
      color: #cdd6f4;
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1rem 0;
    }
    .article-content :global(pre code) {
      background: none;
      padding: 0;
    }
    .article-content :global(img) {
      max-width: 100%;
      border-radius: 6px;
      margin: 1rem 0;
    }
    .article-content :global(hr) {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2rem 0;
    }
  </style>
</Base>
