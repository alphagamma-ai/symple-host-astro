---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import EventCard from '../../components/EventCard.astro';

const tutorials = await getCollection('events', ({ data }) => !data.draft && data.eventType === 'tutorial');
const walkthroughs = await getCollection('walkthroughs', ({ data }) => !data.draft);

const sortedTutorials = tutorials.sort((a, b) => b.data.eventDate.getTime() - a.data.eventDate.getTime());
const sortedWalkthroughs = walkthroughs.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<Base title="Videos" description="Product videos, tutorials, and walkthroughs for learning SympleHost.">
  <nav class="breadcrumb">
    <a href="/">All Topics</a>
    <span class="sep">/</span>
    <span>Videos</span>
  </nav>

  <header class="page-header">
    <p class="eyebrow">Watch and learn</p>
    <h1 class="page-title">Videos</h1>
    <p class="page-desc">Start with the welcome video, then explore focused product walkthroughs by area.</p>
  </header>

  {sortedTutorials.length > 0 && (
    <section class="section">
      <h2 class="section-heading">Featured Videos</h2>
      <div class="grid grid-featured">
        {sortedTutorials.map((video) => <EventCard event={video} hrefBase="/videos" />)}
      </div>
    </section>
  )}

  {sortedWalkthroughs.length > 0 && (
    <section class="section">
      <h2 class="section-heading">Product Walkthroughs</h2>
      <div class="walkthrough-grid">
        {sortedWalkthroughs.map((video) => {
          const thumb = video.data.youtubeId ? `https://i.ytimg.com/vi/${video.data.youtubeId}/hqdefault.jpg` : video.data.poster;
          return (
            <a class="walkthrough-card" href={`/videos/walkthroughs/#${video.id}`}>
              {thumb && (
                <div class="walkthrough-thumb">
                  <img src={thumb} alt="" loading="lazy" />
                </div>
              )}
              <div class="walkthrough-body">
                <h3 class="walkthrough-title">{video.data.title}</h3>
                {video.data.duration && <p class="walkthrough-duration">{video.data.duration}</p>}
                {video.data.description && <p class="walkthrough-desc">{video.data.description}</p>}
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {sortedTutorials.length === 0 && sortedWalkthroughs.length === 0 && (
    <p class="empty">No videos published yet. Check back soon.</p>
  )}

  <style>
    .breadcrumb {
      font-size: 0.85rem;
      color: var(--muted-foreground);
      margin-bottom: 1rem;
    }
    .breadcrumb a { color: var(--muted-foreground); }
    .breadcrumb a:hover { color: var(--heading-color); }
    .sep { margin: 0 0.4rem; }

    .page-header {
      margin-bottom: 2.5rem;
      max-width: 48rem;
    }
    .eyebrow {
      color: var(--primary);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }
    .page-title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--heading-color);
      letter-spacing: -0.01em;
      margin-bottom: 0.5rem;
    }
    .page-desc {
      color: var(--muted-foreground);
      font-size: 1rem;
    }
    .section {
      margin-bottom: 3rem;
    }
    .section-heading {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted-foreground);
      margin: 0 0 1rem;
    }
    .grid {
      display: grid;
      gap: 1.25rem;
    }
    .grid-featured {
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    }
    .walkthrough-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .walkthrough-card {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--foreground);
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .walkthrough-card:hover {
      border-color: var(--primary-300);
      box-shadow: 0 2px 8px rgba(127, 86, 217, 0.1);
    }
    .walkthrough-thumb {
      aspect-ratio: 16 / 9;
      background: var(--primary-50);
    }
    .walkthrough-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .walkthrough-body {
      padding: 1rem 1.1rem 1.15rem;
    }
    .walkthrough-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--heading-color);
      line-height: 1.35;
      margin: 0;
    }
    .walkthrough-duration {
      color: var(--muted-light);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-top: 0.35rem;
    }
    .walkthrough-desc {
      color: var(--muted-foreground);
      font-size: 0.875rem;
      line-height: 1.5;
      margin-top: 0.45rem;
    }
    .empty {
      color: var(--muted-foreground);
      font-size: 0.95rem;
      padding: 2rem 0;
    }
  </style>
</Base>
