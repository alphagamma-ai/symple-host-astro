---
import { getCollection } from 'astro:content';
import ArticlePage from '../../../components/localized/ArticlePage.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  const categories = await getCollection('categories');
  const catMap = new Map(categories.map((c) => [c.id, c]));

  return articles.map((article) => ({
    params: { category: article.data.category, slug: article.id },
    props: { article, category: catMap.get(article.data.category) },
  }));
}

const { article, category } = Astro.props;
---

<ArticlePage article={article} category={category} locale="id" />
