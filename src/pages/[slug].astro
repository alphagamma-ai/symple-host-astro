---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<Base title={`${page.data.title} — SympleHost`} description={page.data.description}>
  <article>
    <h1 class="page-title">{page.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .page-title {
      font-size: 2rem;
      font-weight: 800;
      color: var(--foreground);
      margin-bottom: 2rem;
      letter-spacing: -0.02em;
    }
    .prose :global(h2) { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--foreground); }
    .prose :global(h3) { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; color: var(--foreground); }
    .prose :global(p) { margin-bottom: 1rem; color: var(--foreground); }
    .prose :global(ul), .prose :global(ol) { margin-bottom: 1rem; padding-left: 1.5rem; }
    .prose :global(li) { margin-bottom: 0.25rem; }
    .prose :global(a) { color: var(--primary); }
    .prose :global(img) { max-width: 100%; border-radius: var(--radius); margin: 1rem 0; }
  </style>
</Base>
